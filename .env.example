# ──────────────────────────────────────────────────────────────────────────────
# Dashboard AdvBox — Variáveis de ambiente
# Copie este arquivo para `.env` (no Replit: vá em Secrets) e preencha.
# ──────────────────────────────────────────────────────────────────────────────

# ── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Sessão (OBRIGATÓRIO) ──────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
SESSION_MAX_AGE_MS=43200000

# ── Login ─────────────────────────────────────────────────────────────────────
ADMIN_USER=eduardo
ADMIN_PASS=
TEAM_USER=time
TEAM_PASS=

# ── API Key (acesso somente-leitura admin via header X-Api-Key) ───────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
READ_API_KEY=

# ── CORS — domínios permitidos (separados por vírgula, sem espaço) ────────────
# Em prod, liste APENAS os domínios reais (Replit, etc):
CORS_ORIGINS=https://seu-dashboard.repl.co,https://seu-dominio.com.br

# ── AdvBox API ────────────────────────────────────────────────────────────────
ADVBOX_TOKEN=
ADVBOX_BASE_URL=https://app.advbox.com.br/api/v1

# ── Meta Ads (opcional) ───────────────────────────────────────────────────────
META_TOKEN=
META_AD_ACCOUNT=act_654132083965752
META_API_VERSION=v19.0

# ── ChatGuru (WhatsApp) ───────────────────────────────────────────────────────
CHATGURU_BASE_URL=https://s22.chatguru.app/api/v1
CHATGURU_ACCOUNT_ID=
CHATGURU_PHONE_ID=
CHATGURU_API_KEY=
CHATGURU_WEBHOOK_SECRET=

# ── Banco (PostgreSQL) ────────────────────────────────────────────────────────
DATABASE_URL=
DB_POOL_MAX=10

# ── Limites e rate-limits ─────────────────────────────────────────────────────
LIMIT_BODY_JSON=1mb
LIMIT_UPLOAD_BYTES=15728640
RATE_LOGIN_MAX=5
RATE_LOGIN_WINDOW_MS=900000
RATE_API_MAX=600
RATE_API_WINDOW_MS=60000
